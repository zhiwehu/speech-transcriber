# Speech Transcriber 环境变量配置
# 复制此文件为 .env 并填写真实值

# ==================== 运行模式 ====================
# online: 使用阿里云 API
# local: 使用本地模型
MODE=online

# ==================== 阿里云 DashScope ====================
# 获取：https://dashscope.console.aliyun.com/
DASHSCOPE_API_KEY=sk-YOUR_API_KEY

# ==================== 阿里云 OSS ====================
# 获取：https://oss.console.aliyun.com/
OSS_BUCKET=your-bucket-name
OSS_ENDPOINT=oss-cn-beijing.aliyuncs.com
OSS_ACCESS_KEY=LTAIYOUR_ACCESS_KEY
OSS_ACCESS_SECRET=your-access-secret

# ==================== 本地模式（可选）====================
# 设备：cpu, cuda, npu
LOCAL_DEVICE=cpu

# Intel OpenVINO 加速：true, false
LOCAL_USE_OPENVINO=false
